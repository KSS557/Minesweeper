<Window x:Class="Minesweeper.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Minesweeper"
        mc:Ignorable="d"
        Title="Сапер"
        Height="400"
        Width="250"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid x:Name="PanelSettings" Visibility="Visible" Margin="0">

            <StackPanel Orientation="Vertical" Height="370" Width="220" Margin="5,5,5,0" VerticalAlignment="Top">

                <Border BorderBrush="Black" BorderThickness="1" CornerRadius="10" Margin="0">
                    <StackPanel Orientation="Vertical" Margin="0,0,0,0">
                        <TextBlock Text="Сложность" VerticalAlignment="Center" TextAlignment="Center"/>
                        <StackPanel VerticalAlignment="Center" Width="220" Orientation="Horizontal">
                            <StackPanel Orientation="Vertical" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="5,5,5,5">

                                <RadioButton x:Name="Easy"
                                         GroupName="Difficulty"
                                         Content="Легкая"
                                         IsChecked="True"
                                         Margin="2" />

                                <RadioButton x:Name="Medium"
                                         GroupName="Difficulty"
                                         Content="Средняя"
                                         Margin="2" />

                                <RadioButton x:Name="Hard"
                                         GroupName="Difficulty"
                                         Content="Сложная"
                                         Margin="2" />

                                <RadioButton x:Name="Custom"
                                         GroupName="Difficulty"
                                         Content="Кастомная"
                                         Margin="2" />

                            </StackPanel>

                            <StackPanel Width="120" Margin="5,5,5,5" >
                                <StackPanel Orientation="Horizontal" Width="115">

                                    <TextBlock Text="Размеры: " VerticalAlignment="Center"/>

                                    <TextBox x:Name="TxtWidth"
                                     Text="9"
                                     Width="20"
                                     Margin="0,0,5,0"
                                     IsEnabled="{Binding IsChecked, ElementName=Custom}"/>

                                    <TextBlock Text="x"
                                       VerticalAlignment="Center"
                                       Margin="0,0,5,0" />

                                    <TextBox x:Name="TxtHeight"
                                     Text="9"
                                     Width="20"
                                     Margin="0,0,10,0"
                                     IsEnabled="{Binding IsChecked, ElementName=Custom}"/>

                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Width="115" Margin="0,10,0,0">

                                    <TextBlock Text="Мины: " VerticalAlignment="Center"/>

                                    <TextBox x:Name="Mine"
                                     Text="10"
                                     Width="35"
                                     IsEnabled="{Binding IsChecked, ElementName=Custom}"/>

                                </StackPanel>

                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <StackPanel Orientation="Vertical" Width="220" VerticalAlignment="Top">

                    <Button x:Name="BtnPlay"
                        Content="Играть"
                        Margin="5,10,5,0"
                        Padding="10,5"
                        FontSize="14"
                        HorizontalAlignment="Stretch">

                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Blue"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="BorderBrush" Value="DarkGray"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="5"
                                                Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center" />
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#3A7BD5"/>
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="Cursor" Value="Hand"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter Property="Background" Value="#2C5DAA"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>

                    </Button>

                    <Button x:Name="BtnLeaderboard"
                            Content="Таблица лидеров"
                            Margin="5,10,5,0"
                            Padding="10,5"
                            FontSize="14"
                            HorizontalAlignment="Stretch">

                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Blue"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="BorderBrush" Value="DarkGray"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="5"
                            Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#3A7BD5"/>
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="Cursor" Value="Hand"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter Property="Background" Value="#2C5DAA"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>

                    </Button>

                </StackPanel>

            </StackPanel>
        </Grid>

        <Grid x:Name="PanelGame" Visibility="Collapsed" Margin="0">

            <!-- Строки игровые: 0 — таймер и кнопки, 1 — поле -->
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 1. Строка сверху: таймер и кнопки -->
            <ContentControl x:Name="HeaderContainer" Grid.Row="0" HorizontalAlignment="Stretch" VerticalAlignment="Center"/>

            <!-- 2. Строкa с полем -->
            <Grid Grid.Row="1" Margin="0">

                <ScrollViewer x:Name="GameScrollViewer"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto"
                              PreviewMouseWheel="GameScrollViewer_PreviewMouseWheel">

                    <!-- Canvas как "полотно" для фикс. позиций, как в html -->
                    <Canvas x:Name="BoardCanvas" Margin="0" />

                </ScrollViewer>

            </Grid>

            <Grid x:Name="DialogOverlay" Visibility="Collapsed" Grid.RowSpan="2">
                
                <Grid.Background>
                    <SolidColorBrush Color="Black" Opacity="0.6" />
                </Grid.Background>

                <Border HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Background="White"
                        BorderBrush="DarkGray"
                        BorderThickness="1"
                        Padding="50"
                        CornerRadius="10">

                    <StackPanel>
                        <TextBlock
                        Text="Пауза"
                        FontWeight="Bold"
                        FontSize="16"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,10" />

                        <Button
                        x:Name="BtnResume"
                        Content="Продолжить"
                        Height="30"
                        Margin="0,0,0,5" />

                        <Button
                        x:Name="BtnQuit"
                        Content="Выйти в меню"
                        Height="30" />

                    </StackPanel>

                </Border>

            </Grid>

            <Grid x:Name="WinOverlay" Visibility="Collapsed" Grid.RowSpan="2">

                <Grid.Background>
                    <SolidColorBrush Color="Black" Opacity="0.6" />
                </Grid.Background>
                
                <Border HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Background="#80FFFFFF"
                        BorderBrush="DarkGray"
                        BorderThickness="1"
                        Padding="50"
                        CornerRadius="10">

                    <StackPanel>
                        <TextBlock
                        Text="Победа"
                        FontWeight="Bold"
                        FontSize="16"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,10" />

                        <Button
                        x:Name="BtnWinLeaderBoard"
                        Content="Таблица лидеров"
                        Height="30"
                        Margin="0,0,0,5" />

                        <Button
                        x:Name="BtnWinQuit"
                        Content="Выйти в меню"
                        Height="30" />

                        <Button
                        x:Name="BtnWinExit"
                        Content="Закрыть"
                        Height="30" />

                    </StackPanel>

                </Border>

            </Grid>

            <Grid x:Name="LoseOverlay" Visibility="Collapsed" Grid.RowSpan="2">
                
                <Grid.Background>
                    <SolidColorBrush Color="Black" Opacity="0.6" />
                </Grid.Background>

                <Border HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Background="#80FFFFFF"
                        BorderBrush="DarkGray"
                        BorderThickness="1"
                        Padding="50"
                        CornerRadius="10">

                    <StackPanel>
                        <TextBlock
                        Text="Проигрыш"
                        FontWeight="Bold"
                        FontSize="16"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,10" />

                        <Button
                        x:Name="BtnLoseRestart"
                        Content="Заново"
                        Height="30"
                        Margin="0,0,0,5" />

                        <Button
                        x:Name="BtnLouseQuit"
                        Content="Выйти в меню"
                        Height="30" />

                        <Button
                        x:Name="BtnLoseExit"
                        Content="Закрыть"
                        Height="30" />

                    </StackPanel>

                </Border>

            </Grid>

        </Grid>

        <Grid x:Name="Leaderboard" Visibility="Collapsed" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- Заголовок -->
                <RowDefinition Height="*"/>
                <!-- Таблица -->
                <RowDefinition Height="Auto"/>
                <!-- Кнопки -->
            </Grid.RowDefinitions>

            <!-- Заголовок -->
            <Border Grid.Row="0" Background="#1E3A8A" CornerRadius="10" Padding="20" Margin="0,0,0,10">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="🏆 ТАБЛИЦА ЛИДЕРОВ" 
                       Foreground="White" 
                       FontSize="24" 
                       FontWeight="Bold"
                       VerticalAlignment="Center"/>
                    <Button x:Name="BtnBackToMenu" 
                            Content="← Главное меню" 
                            Margin="20,0,0,0"
                            Padding="10,5"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            Foreground="White"
                            Cursor="Hand"/>
                </StackPanel>
            </Border>

            <!-- Кнопки сложности -->
            <StackPanel Grid.Row="0" 
                Orientation="Horizontal" 
                HorizontalAlignment="Center" 
                Margin="0,60,0,10">
                <Button x:Name="BtnEasy" Content="Лёгкая" Margin="5" Padding="12,8" Tag="Easy"/>
                <Button x:Name="BtnMedium" Content="Средняя" Margin="5" Padding="12,8" Tag="Medium"/>
                <Button x:Name="BtnHard" Content="Сложная" Margin="5" Padding="12,8" Tag="Hard"/>
                <Button x:Name="BtnCustom" Content="Кастом" Margin="5" Padding="12,8" Tag="Custom"/>
            </StackPanel>

            <!-- Таблица лидеров -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <DataGrid x:Name="LeaderboardTable" 
                  AutoGenerateColumns="False"
                  CanUserSortColumns="True"
                  IsReadOnly="True"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  SelectionMode="Single"
                  Background="White"
                  BorderThickness="1"
                  Margin="0,0,0,10">

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="🏆" Width="50" 
                                    Binding="{Binding Rank}" 
                                    />
                        <DataGridTextColumn Header="Игрок" Width="*" 
                                    Binding="{Binding PlayerName}">
                            <DataGridTextColumn.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#EFF6FF"/>
                                            <Setter Property="Cursor" Value="Hand"/>
                                        </Trigger>
                                    </Style.Triggers>
                                    <Setter Property="Padding" Value="10,8"/>
                                </Style>
                            </DataGridTextColumn.CellStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Сложность" Width="120" 
                                    Binding="{Binding Difficulty}" 
                                    />
                        <DataGridTextColumn Header="⏱️ Время" Width="100" 
                                    Binding="{Binding Time}" 
                                    />
                    </DataGrid.Columns>
                </DataGrid>
            </ScrollViewer>

            <!-- Кнопка "Показать всех" / "Общая таблица" -->
            <Button Grid.Row="2" x:Name="BtnToggleView" 
            Content="👤 Показать всех игроков"
            HorizontalAlignment="Center" 
            Margin="0,0,0,20"
            Padding="20,10"/>
        </Grid>

    </Grid>
</Window>
