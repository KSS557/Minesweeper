<Window x:Class="Minesweeper.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Minesweeper"
        mc:Ignorable="d"
        Title="Сапер"
        Height="400"
        Width="250"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style x:Key="GameButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#3B82F6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Margin" Value="1"/>
            <Setter Property="UseLayoutRounding" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <!-- Тень как фон под кнопкой -->
                            <Border Background="#1D4ED8"
                            Opacity="0.2"
                            CornerRadius="8"
                            Margin="1"/>

                            <!-- Сама кнопка без эффекта -->
                            <Border x:Name="Border"
                            Background="{TemplateBinding Background}"
                            CornerRadius="8"
                            UseLayoutRounding="True"
                            SnapsToDevicePixels="True">
                                <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                            </Border>
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#2563EB"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#1D4ED8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#3B82F6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border" 
                            Background="{TemplateBinding Background}"
                            CornerRadius="18"
                            Width="{TemplateBinding Width}"
                            Height="{TemplateBinding Height}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <Border.Effect>
                                <DropShadowEffect Color="#1D4ED8" 
                                              Opacity="0.4"
                                              ShadowDepth="2" 
                                              BlurRadius="6"/>
                            </Border.Effect>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#2563EB"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#1D4ED8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GameTitleStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,0,10"/>

            <!-- Border вокруг текста -->
            

            <!-- Тень для Border -->
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#1E40AF" 
                              Opacity="0.4"
                              ShadowDepth="2" 
                              BlurRadius="8"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CustomTitleLabelStyle" TargetType="Label">
            <Setter Property="Content" Value="🏆 ТАБЛИЦА ЛИДЕРОВ"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Top"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Label">
                        <Border Background="#3B82F6" 
                        CornerRadius="10" 
                        Padding="5">

                            <!-- Grid для точного центрирования -->
                            <Grid>
                                <TextBlock Text="{TemplateBinding Content}"
                                   Foreground="White"
                                   FontSize="24" 
                                   FontWeight="Bold"
                                   TextAlignment="Center"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                            </Grid>

                            <Border.Effect>
                                <DropShadowEffect Color="#1D4ED8" Opacity="0.4" ShadowDepth="2" BlurRadius="8"/>
                            </Border.Effect>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    
    <Grid>
        <Grid x:Name="PanelSettings" Visibility="Visible" Margin="0">
    
            <StackPanel Orientation="Vertical" Height="370" Width="220" Margin="5,5,5,0" VerticalAlignment="Top">
                <Label Content="Настройки игры" Style="{StaticResource CustomTitleLabelStyle}"/>

                <Border BorderBrush="Black" BorderThickness="1" CornerRadius="10" Margin="0">
                    <StackPanel Orientation="Vertical" Margin="0,0,0,0">
                        <TextBlock Text="Сложность" VerticalAlignment="Center" TextAlignment="Center"/>
                        <StackPanel VerticalAlignment="Center" Width="220" Orientation="Horizontal">
                            <StackPanel Orientation="Vertical" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="5,5,5,5">

                                <RadioButton x:Name="Easy"
                                         GroupName="Difficulty"
                                         Content="Легкая"
                                         IsChecked="True"
                                         Margin="2" />

                                <RadioButton x:Name="Medium"
                                         GroupName="Difficulty"
                                         Content="Средняя"
                                         Margin="2" />

                                <RadioButton x:Name="Hard"
                                         GroupName="Difficulty"
                                         Content="Сложная"
                                         Margin="2" />

                                <RadioButton x:Name="Custom"
                                         GroupName="Difficulty"
                                         Content="Кастомная"
                                         Margin="2" />

                            </StackPanel>

                            <StackPanel Width="120" Margin="5,5,5,5" >
                                <StackPanel Orientation="Horizontal" Width="115">

                                    <TextBlock Text="Размеры: " VerticalAlignment="Center"/>

                                    <TextBox x:Name="TxtWidth"
                                     Text="9"
                                     Width="20"
                                     Margin="0,0,5,0"
                                     IsEnabled="{Binding IsChecked, ElementName=Custom}"/>

                                    <TextBlock Text="x"
                                       VerticalAlignment="Center"
                                       Margin="0,0,5,0" />

                                    <TextBox x:Name="TxtHeight"
                                     Text="9"
                                     Width="20"
                                     Margin="0,0,10,0"
                                     IsEnabled="{Binding IsChecked, ElementName=Custom}"/>

                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Width="115" Margin="0,10,0,0">

                                    <TextBlock Text="Мины: " VerticalAlignment="Center"/>

                                    <TextBox x:Name="Mine"
                                     Text="10"
                                     Width="35"
                                     IsEnabled="{Binding IsChecked, ElementName=Custom}"/>

                                </StackPanel>

                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <StackPanel Orientation="Vertical" Width="220" VerticalAlignment="Top">

                    <Button x:Name="BtnPlay"
                            Content="Играть"
                            Margin="5,10,5,0"
                            Padding="10,5"
                            FontSize="14"
                            HorizontalAlignment="Stretch"
                            Height="25"
                            Style="{StaticResource GameButtonStyle}"/>

                    <Button x:Name="BtnLeaderboard"
                            Content="Таблица лидеров"
                            Margin="5,10,5,0"
                            Padding="10,5"
                            FontSize="14"
                            HorizontalAlignment="Stretch"
                            Height="25"
                            Style="{StaticResource GameButtonStyle}"/>

                </StackPanel>

            </StackPanel>
        </Grid>

        <Grid x:Name="PanelGame" Visibility="Collapsed" Margin="0">

            <!-- Строки игровые: 0 — таймер и кнопки, 1 — поле -->
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 1. Строка сверху: таймер и кнопки -->
            <ContentControl x:Name="HeaderContainer" Grid.Row="0" HorizontalAlignment="Stretch" VerticalAlignment="Center"/>

            <!-- 2. Строкa с полем -->
            <Grid Grid.Row="1" Margin="0">

                <ScrollViewer x:Name="GameScrollViewer"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto"
                              PreviewMouseWheel="GameScrollViewer_PreviewMouseWheel">

                    <!-- Canvas как "полотно" для фикс. позиций, как в html -->
                    <Canvas x:Name="BoardCanvas" Margin="0" />

                </ScrollViewer>

            </Grid>

            <Grid x:Name="DialogOverlay" Visibility="Collapsed" Grid.RowSpan="2">

                <Grid.Background>
                    <SolidColorBrush Color="Black" Opacity="0.6" />
                </Grid.Background>

                <Border HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Background="White"
                        BorderBrush="DarkGray"
                        BorderThickness="1"
                        Padding="50"
                        CornerRadius="10">

                    <StackPanel>
                        <TextBlock Text="Пауза"
                                   FontWeight="Bold"
                                   FontSize="16"
                                   HorizontalAlignment="Center"/>

                        <Button x:Name="BtnResume"
                                Content="Продолжить"
                                Height="30"
                                Width="100"
                                Style="{StaticResource GameButtonStyle}"/>

                        <Button x:Name="BtnQuit"
                                Content="Выйти в меню"
                                Height="30" 
                                Width="100"
                                Style="{StaticResource GameButtonStyle}"/>

                    </StackPanel>

                </Border>

            </Grid>

            <Grid x:Name="WinOverlay" Visibility="Collapsed" Grid.RowSpan="2">

                <Grid.Background>
                    <SolidColorBrush Color="Black" Opacity="0.6" />
                </Grid.Background>

                <Border HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Background="#80FFFFFF"
                        BorderBrush="DarkGray"
                        BorderThickness="1"
                        Padding="50"
                        CornerRadius="10">

                    <StackPanel>
                        <TextBlock Text="Победа"
                                   FontWeight="Bold"
                                   FontSize="16"
                                   HorizontalAlignment="Center"/>

                        <Button x:Name="BtnWinLeaderBoard"
                                Content="Запись рекорда"
                                Height="30"
                                Width="100"
                                Style="{StaticResource GameButtonStyle}"/>

                        <Button x:Name="BtnWinQuit"
                                Content="Выйти в меню"
                                Height="30" 
                                Width="100"
                                Style="{StaticResource GameButtonStyle}"/>

                        <Button x:Name="BtnWinExit"
                                Content="Закрыть"
                                Height="30" 
                                Width="100"
                                Style="{StaticResource GameButtonStyle}"/>

                    </StackPanel>

                </Border>

            </Grid>

            <Grid x:Name="LoseOverlay" Visibility="Collapsed" Grid.RowSpan="2">

                <Grid.Background>
                    <SolidColorBrush Color="Black" Opacity="0.6" />
                </Grid.Background>

                <Border HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Background="#80FFFFFF"
                        BorderBrush="DarkGray"
                        BorderThickness="1"
                        Padding="50"
                        CornerRadius="10">

                    <StackPanel>
                        <TextBlock Text="Проигрыш"
                                   FontWeight="Bold"
                                   FontSize="16"
                                   HorizontalAlignment="Center"/>

                        <Button x:Name="BtnLoseRestart"
                                Content="Заново"
                                Height="30"
                                Width="100"
                                Style="{StaticResource GameButtonStyle}"/>

                        <Button x:Name="BtnLouseQuit"
                                Content="Выйти в меню"
                                Height="30" 
                                Width="100"
                                Style="{StaticResource GameButtonStyle}"/>

                        <Button x:Name="BtnLoseExit"
                                Content="Закрыть"
                                Height="30" 
                                Width="100"
                                Style="{StaticResource GameButtonStyle}"/>

                    </StackPanel>

                </Border>

            </Grid>

        </Grid>

        <Grid x:Name="Leaderboard" Visibility="Collapsed" Margin="5">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- Заголовок -->
                <RowDefinition Height="Auto"/>
                <!-- Таблица -->
                <RowDefinition/>

                <RowDefinition Height="Auto"/>
                <!-- Кнопки -->
            </Grid.RowDefinitions>

            <!-- Заголовок -->
            <Button x:Name="BtnBackToMenu" 
                    Content="←"
                    Margin="5"
                    Width="36" Height="36"
                    Cursor="Hand"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Style="{StaticResource MenuButtonStyle}"/>

            <Label Content="🏆 ТАБЛИЦА ЛИДЕРОВ" Foreground="White" Style="{StaticResource CustomTitleLabelStyle}"/>

            <!-- Кнопки сложности -->
            <StackPanel Grid.Row="1" 
                        Orientation="Horizontal" 
                        HorizontalAlignment="Left">

                <Button x:Name="BtnEasy" Content="Лёгкая" Margin="5" Tag="Easy" Style="{StaticResource GameButtonStyle}" Height="20" Width="60"/>
                <Button x:Name="BtnMedium" Content="Средняя" Margin="5" Tag="Medium" Style="{StaticResource GameButtonStyle}" Height="20" Width="60"/>
                <Button x:Name="BtnHard" Content="Сложная" Margin="5" Tag="Hard" Style="{StaticResource GameButtonStyle}" Height="20" Width="60"/>
                <Button x:Name="BtnCustom" Content="Кастомная" Margin="5" Tag="Custom" Style="{StaticResource GameButtonStyle}" Height="20" Width="60"/>
                
            </StackPanel>

            <!-- Таблица лидеров -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                <DataGrid x:Name="LeaderboardTable" 
                          AutoGenerateColumns="False"
                          CanUserSortColumns="True"
                          IsReadOnly="True"
                          GridLinesVisibility="Horizontal"
                          HeadersVisibility="Column"
                          SelectionMode="Single"
                          Background="White"
                          BorderThickness="1"
                          Margin="0,0,0,10" SelectionChanged="LeaderboardTable_SelectionChanged">

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="🏆" Width="50" 
                                    Binding="{Binding Rank}" 
                                    />
                        <DataGridTextColumn Header="Игрок" Width="*" 
                                    Binding="{Binding PlayerName}">
                            <DataGridTextColumn.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#EFF6FF"/>
                                            <Setter Property="Cursor" Value="Hand"/>
                                        </Trigger>
                                    </Style.Triggers>
                                    <Setter Property="Padding" Value="10,8"/>
                                </Style>
                            </DataGridTextColumn.CellStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Сложность" Width="140" 
                                    Binding="{Binding Difficulty}" 
                                    />
                        <DataGridTextColumn Header="⏱️ Время" Width="120" 
                                    Binding="{Binding Time}" 
                                    />
                    </DataGrid.Columns>
                </DataGrid>
            </ScrollViewer>

            <!-- Кнопка "Показать всех" / "Общая таблица" -->
            <Button Grid.Row="3" x:Name="BtnToggleView" 
                    Content="👤 Показать всех игроков"
                    HorizontalAlignment="Center" 
                    Margin="0,0,0,20"
                    Width="150"
                    Height="25"
                    Style="{StaticResource GameButtonStyle}"/>
        </Grid>

    </Grid>
</Window>
