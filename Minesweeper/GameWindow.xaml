<Window x:Class="Minesweeper.GameWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Сапёр" ResizeMode="CanResize" SizeToContent="WidthAndHeight">

    <Grid>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Height="40" Margin="0,0,0,5">

            <TextBlock Name="TimerText" Text="00:00" Margin="0,0,20,0" VerticalAlignment="Center" FontWeight="SemiBold" />

            <Button Content="Заново"
        Margin="0,0,10,0"
        Padding="10,3"
        x:Name="BtnRestart"
        Width="80"
        FontWeight="SemiBold" />

            <Button Content="Назад в меню"
        Margin="0,0,0,0"
        Padding="10,3"
        x:Name="BtnBackToMenu"
        Width="120"
        FontWeight="SemiBold" />

        </StackPanel>


        <ScrollViewer HorizontalScrollBarVisibility="Auto"
              VerticalScrollBarVisibility="Auto">
            <Grid x:Name="BoardGrid" Margin="5"/>
        </ScrollViewer>

    </Grid>
</Window>